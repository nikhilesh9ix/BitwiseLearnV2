# AWS Production Environment Configuration
# Copy this file to .env.prod and fill in your AWS-specific values

# ===================================
# AWS Configuration
# ===================================
AWS_ACCOUNT_ID=your-account-id
AWS_REGION=us-east-1
AWS_ENVIRONMENT=production

# ===================================
# Database Configuration
# ===================================
# Production database connection string
DATABASE_URL=<db_connection_string>

# ===================================
# RabbitMQ Configuration
# ===================================
# Option 1: Using AWS MQ (managed RabbitMQ)
MQ_CLIENT=amqp://bitwise_user:your_password@your-mq-endpoint.mq.us-east-1.amazonaws.com:5672/

# Option 2: Using self-hosted RabbitMQ on EC2/Container
# MQ_CLIENT=amqp://guest:guest@rabbitmq:5672/

# RabbitMQ credentials for docker-compose
RABBITMQ_USER=bitwise_user
RABBITMQ_PASSWORD=your_secure_password

# ===================================
# Authentication & Secrets
# ===================================
# JWT Secret
JWT_SECRET=your-very-long-and-secure-jwt-secret-key-here

# OAuth providers (if needed)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===================================
# Frontend Configuration
# ===================================
# API endpoint for frontend
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ===================================
# Service Ports
# ===================================
# (Internal container ports - generally don't change)
GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
COURSE_SERVICE_PORT=8003
PROBLEM_SERVICE_PORT=8004
ASSESSMENT_SERVICE_PORT=8005
CODE_SERVICE_PORT=8006
NOTIFICATION_SERVICE_PORT=8007
REPORT_SERVICE_PORT=8008
FRONTEND_PORT=3000
PISTON_PORT=2000

# ===================================
# Email Configuration
# ===================================
# For AWS SES (Simple Email Service)
MAIL_FROM=noreply@yourdomain.com
MAIL_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=your-ses-user
MAIL_SMTP_PASSWORD=your-ses-password

# ===================================
# S3 Configuration (for file uploads)
# ===================================
AWS_S3_BUCKET=bitwise-uploads
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ===================================
# Logging & Monitoring
# ===================================
# CloudWatch Log Groups (auto-managed by ECS)
LOG_LEVEL=INFO

# Application Insights (optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ===================================
# Feature Flags
# ===================================
ENABLE_REGISTRATION=true
ENABLE_SOCIAL_LOGIN=false
ENABLE_EMAIL_VERIFICATION=true
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15

# ===================================
# Rate Limiting
# ===================================
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=1

# ===================================
# Timezone & Localization
# ===================================
TZ=UTC
DEFAULT_LOCALE=en-US

# ===================================
# Development/Debug (keep false in production!)
# ===================================
DEBUG=false
SQLALCHEMY_ECHO=false
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===================================
# Cache Configuration (Redis on ElastiCache)
# ===================================
REDIS_URL=redis://your-elasticache-endpoint:6379/0

# ===================================
# Image Configuration
# ===================================
# Docker image tags for deployment
IMAGE_TAG=latest
IMAGE_REGISTRY=your-account-id.dkr.ecr.us-east-1.amazonaws.com
